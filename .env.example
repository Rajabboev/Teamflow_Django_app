    # Django
SECRET_KEY=change-me-to-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used by Django app; DB_HOST must be "db" when using docker-compose)
DB_NAME=teamflow
DB_USER=teamflow_user
DB_PASSWORD=your_db_password_here
DB_HOST=db
DB_PORT=5432

# PostgreSQL container (must match DB_* for the app)
POSTGRES_DB=teamflow
POSTGRES_USER=teamflow_user
POSTGRES_PASSWORD=your_db_password_here

# SSL (False for local, True for production behind HTTPS)
SECURE_SSL_REDIRECT=False

# Optional: create Django superuser on first run
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
